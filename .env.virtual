# This is a file that is used by Vite under 'virtual' development mode
# do not change this variable
VITE_TERRA_VIRTUAL=true

# This is the path where the production version of the app will be deployed
VITE_BASE = ./

# This is the log level that Vite will use to log messages
VITE_LOG_LEVEL=info

# Defines the base path or URL to assets, like CSS, JavaScript, or images
# change the name of your wordpress install and theme accordingly
VITE_WP_PATH = ./wp-content/themes/wp-starter-kit/public

